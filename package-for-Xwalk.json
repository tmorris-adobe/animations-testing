{
  "name": "@adobe/aem-block-collection",
  "private": true,
  "version": "1.0.0",
  "description": "Block collection for AEM",
  "scripts": {
    "lint:js": "eslint . --ext .json,.js,.mjs",
    "lint:css": "stylelint blocks/**/*.css styles/*.css",
    "fix-css": " stylelint --fix **/**/*.css",
    "fix-js": "eslint --fix **/**/*.js",
    "lint": "npm run lint:js && npm run lint:css",
    "build:json": "npm-run-all -p build:json:models build:json:definitions build:json:filters",
    "build:json:models": "merge-json-cli -i \"models/_component-models.json\" -o \"component-models.json\"",
    "build:json:definitions": "merge-json-cli -i \"models/_component-definition.json\" -o \"component-definition.json\"",
    "build:json:filters": "merge-json-cli -i \"models/_component-filters.json\" -o \"component-filters.json\"",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adobe/aem-block-collection.git"
  },
  "author": "Adobe",
  "license": "Apache License 2.0",
  "bugs": {
    "url": "https://github.com/adobe/aem-block-collection/issues"
  },
  "homepage": "https://github.com/adobe/aem-block-collection#readme",
  "overrides": {
    "css-tree": "3.2.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/eslint-parser": "7.28.0",
    "chai": "5.0.0",
    "enhanced-resolve": "^5.19.0",
    "eslint": "8.57.1",
    "eslint-config-airbnb-base": "15.0.0",
    "eslint-plugin-browser-security": "^1.2.3",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-json": "3.1.0",
    "eslint-plugin-secure-coding": "^3.1.3",
    "eslint-plugin-sonarjs": "^3.0.7",
    "eslint-plugin-xwalk": "github:adobe-rnd/eslint-plugin-xwalk#v0.1.3",
    "get-tsconfig": "^4.13.6",
    "globals": "^17.3.0",
    "husky": "9.1.1",
    "merge-json-cli": "^1.0.4",
    "npm-run-all": "^4.1.5",
    "stylelint": "17.4.0",
    "stylelint-config-standard": "40.0.0",
    "ts-api-utils": "^2.4.0"
  }
}
